# ─────────────────────────────────────────────────────────────
# ScribIA — Environment Variables Template
# ─────────────────────────────────────────────────────────────
# Copy this to .env.local for local development.
# For Vercel deployment, set these in Project Settings > Environment Variables.
# NEVER commit actual secrets to the repository.
# ─────────────────────────────────────────────────────────────

# JWT Secret (REQUIRED in production — use a strong random string)
# Generate with: openssl rand -base64 48
JWT_SECRET=

# Supabase (REQUIRED for production)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Gemini AI (REQUIRED for AI corrections in production)
GEMINI_API_KEY=
